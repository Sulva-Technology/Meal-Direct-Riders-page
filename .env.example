# Meal Direct backend API base URL (must include /v1).
# Exposed to the browser via Vite, so it MUST be prefixed with VITE_.
VITE_API_BASE_URL="https://mealdirectbackend.onrender.com/v1"

# Where Supabase auth emails (signup confirm, password reset) redirect back to.
# Must be added to your Supabase Auth → URL Configuration → Redirect URLs allowlist.
VITE_AUTH_REDIRECT_URL="https://rider.mealdirectly.com/auth/callback"

# Firebase Cloud Messaging "Web Push certificate" public key (vapidKey).
# Firebase console → Project settings → Cloud Messaging → Web Push certificates.
VITE_WEB_PUSH_PUBLIC_KEY=""

# Rider support contact channels (surfaced on the Support screen).
VITE_SUPPORT_PHONE="+2348000000000"
VITE_SUPPORT_WHATSAPP="+2348000000000"
VITE_SUPPORT_EMAIL="riders@mealdirectly.com"
